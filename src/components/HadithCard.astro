---
interface Props {
  bookName: string;
  hadithNumber: string | number;
  arabicText: string;
  banglaTranslation: string;
  narrator?: string;
  grade?: string;
}

const { bookName, hadithNumber, arabicText, banglaTranslation, narrator, grade } = Astro.props;
---

<article class="bg-white dark:bg-slate-800/40 rounded-2xl p-6 md:p-8 shadow-sm border border-slate-100 dark:border-slate-700/50 mb-8">
  <div class="flex justify-between items-center mb-6 pb-4 border-b border-slate-100 dark:border-slate-700/50">
    <div class="flex items-center gap-3">
      <span class="bg-brand-50 dark:bg-brand-900/30 text-brand-600 dark:text-brand-400 text-xs font-semibold px-3 py-1 rounded-full border border-brand-100 dark:border-brand-800/50">
        {bookName}
      </span>
      <h3 class="text-sm font-semibold text-slate-600 dark:text-slate-400">হাদিস নং {hadithNumber}</h3>
    </div>
    
    {grade && (
      <span class={`text-xs font-bold px-2 py-1 rounded ${grade.includes('সহিহ') ? 'text-green-600 bg-green-50 dark:bg-green-900/20' : 'text-orange-600 bg-orange-50 dark:bg-orange-900/20'}`}>
        {grade}
      </span>
    )}
  </div>

  <div class="mb-8" dir="rtl">
    <p class="font-arabic text-3xl md:text-4xl text-slate-900 dark:text-slate-100 leading-[2.5] md:leading-[2.8]">
      {arabicText}
    </p>
  </div>

  <div class="space-y-3">
    {narrator && (
      <p class="text-sm font-semibold text-brand-600 dark:text-brand-400">
        {narrator} থেকে বর্ণিত:
      </p>
    )}
    <p class="text-lg md:text-xl text-slate-700 dark:text-slate-300 leading-relaxed font-bengali">
      {banglaTranslation}
    </p>
  </div>
</article>
