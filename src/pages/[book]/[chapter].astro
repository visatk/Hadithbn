---
import Layout from '../../layouts/Layout.astro';
import HadithCard from '../../components/HadithCard.astro';

const { book, chapter } = Astro.params;

// Mock Data: পরবর্তীতে D1 Database থেকে ডেটা ফেচ করবেন
const chapterTitle = 'ওহীর সূচনা';
const hadiths = [
  {
    id: 1,
    arabicText: 'إِنَّمَا الأَعْمَالُ بِالنِّيَّاتِ، وَإِنَّمَا لِكُلِّ امْرِئٍ مَا نَوَى',
    banglaTranslation: 'নিশ্চয়ই সমস্ত আমল নিয়তের ওপর নির্ভরশীল। আর প্রত্যেক ব্যক্তি তাই পাবে, যা সে নিয়ত করেছে।',
    narrator: 'উমর ইবনুল খাত্তাব (রাঃ)',
    grade: 'সহিহ বুখারী'
  },
  {
    id: 2,
    arabicText: 'عَائِشَةَ أُمِّ الْمُؤْمِنِينَ أَنَّهَا قَالَتْ كَانَ أَوَّلُ مَا بُدِئَ بِهِ رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ...',
    banglaTranslation: 'আয়িশা (রাঃ) থেকে বর্ণিত যে, রাসূলুল্লাহ (সাল্লাল্লাহু আলাইহি ওয়াসাল্লাম) এর ওহীর সূচনা হয়েছিল ঘুমের মধ্যে সত্য স্বপ্নের মাধ্যমে...',
    narrator: 'আয়িশা (রাঃ)',
    grade: 'সহিহ বুখারী'
  }
];
---

<Layout title={`${chapterTitle} | ${book}`}>
  <div class="mb-8">
    <a href={`/${book}`} class="text-brand-600 hover:text-brand-700 dark:text-brand-400 dark:hover:text-brand-300 text-sm font-medium flex items-center gap-1 mb-4 w-fit">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
      </svg>
      অধ্যায় তালিকায় ফিরে যান
    </a>
    
    <div class="bg-white dark:bg-slate-800/50 p-6 md:p-8 rounded-2xl border border-slate-100 dark:border-slate-700/50 mb-8 flex justify-between items-center">
      <div>
        <span class="text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-1 block">অধ্যায় {chapter}</span>
        <h1 class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-white">{chapterTitle}</h1>
      </div>
      <div class="text-right">
        <span class="text-3xl font-light text-brand-500">{hadiths.length}</span>
        <span class="text-sm text-slate-500 block">হাদিস</span>
      </div>
    </div>
  </div>

  <div class="space-y-6">
    {hadiths.map(hadith => (
      <HadithCard 
        bookName={book === 'bukhari' ? 'সহিহ বুখারী' : 'হাদিস গ্রন্থ'}
        hadithNumber={hadith.id}
        arabicText={hadith.arabicText}
        banglaTranslation={hadith.banglaTranslation}
        narrator={hadith.narrator}
        grade={hadith.grade}
      />
    ))}
  </div>
</Layout>
