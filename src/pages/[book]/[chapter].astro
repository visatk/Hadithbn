---
import Layout from '../../layouts/Layout.astro';
import HadithCard from '../../components/HadithCard.astro';

const { book, chapter } = Astro.params;
const db = Astro.locals.runtime.env.DB;

let hadiths = [];

try {
  // Join 'hadith' table with 'grades' table to get grade names
  const { results } = await db.prepare(`
    SELECT h.hadith_id, h.narrator, h.content, h.ar, g.name_bn as grade_name
    FROM hadith h
    LEFT JOIN grades g ON h.grade_id = g.id
    WHERE h.chapter_id = ?
  `).bind(chapter).all();
  hadiths = results;
} catch (error) {
  console.error("D1 Fetch Error:", error);
}

Astro.response.headers.set('Cache-Control', 'public, max-age=86400, s-maxage=86400, stale-while-revalidate');
---

<Layout title={`অধ্যায় ${chapter} | হাদিস`}>
  <div class="mb-8">
    <a href={`/${book}`} class="text-brand-600 hover:text-brand-700 dark:text-brand-400 dark:hover:text-brand-300 text-sm font-medium flex items-center gap-1 mb-4 w-fit">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
      </svg>
      অধ্যায় তালিকায় ফিরে যান
    </a>
  </div>

  <div class="space-y-6">
    {hadiths.map(hadith => (
      <HadithCard 
        bookName={book.toUpperCase()}
        hadithNumber={hadith.hadith_id}
        arabicText={hadith.ar}
        banglaTranslation={hadith.content}
        narrator={hadith.narrator}
        grade={hadith.grade_name}
      />
    ))}
  </div>
</Layout>
