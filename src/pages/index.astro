---
import Layout from '../layouts/Layout.astro';

// This data will eventually come from your D1 Database via Astro.locals.runtime.env.DB
const books = [
  { id: 'bukhari', title: 'সহিহ বুখারী', total: 7563, description: 'ইসলামের সর্বাধিক বিশুদ্ধ হাদিস গ্রন্থ।' },
  { id: 'muslim', title: 'সহিহ মুসলিম', total: 3033, description: 'ইমাম মুসলিম (রহ.) কর্তৃক সংকলিত বিশুদ্ধ হাদিস।' },
  { id: 'abudawud', title: 'সুনান আবু দাউদ', total: 5274, description: 'ফিকহী মাসআলা সম্বলিত অন্যতম সুনান গ্রন্থ।' },
  { id: 'tirmidhi', title: 'জামে আত-তিরমিযী', total: 3956, description: 'হাদিসের মান এবং ফিকহী আলোচনার জন্য বিখ্যাত।' }
];
---

<Layout title="মূল পাতা">
  <!-- Hero Section -->
  <section class="py-12 md:py-20 text-center">
    <span class="bg-brand-100 dark:bg-brand-900/40 text-brand-600 dark:text-brand-400 text-sm font-semibold px-4 py-1.5 rounded-full mb-6 inline-block">
      বিসমিল্লাহির রাহমানির রাহিম
    </span>
    <h1 class="text-4xl md:text-5xl lg:text-6xl mb-4 leading-tight">
      বিশুদ্ধ হাদিস পড়ুন <br/> <span class="text-brand-600 dark:text-brand-500">সহজ ও সাবলীলভাবে</span>
    </h1>
    <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto mb-10">
      কোনো বিজ্ঞাপন বা ডিস্ট্রাকশন ছাড়াই আপনার মাতৃভাষায় প্রামাণ্য হাদিস অধ্যয়ন করুন।
    </p>
    
    <!-- Search Bar (Static for now) -->
    <div class="max-w-xl mx-auto relative">
      <input 
        type="text" 
        placeholder="হাদিস খুঁজুন (যেমন: সালাত, রোজা...)" 
        class="w-full bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl px-6 py-4 text-lg focus:outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 transition-all shadow-sm"
      />
      <button class="absolute right-3 top-3 bg-brand-600 hover:bg-brand-700 text-white p-2 rounded-xl transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
        </svg>
      </button>
    </div>
  </section>

  <!-- Books Grid -->
  <section class="py-10">
    <h2 class="text-2xl mb-8 flex items-center gap-2">
      <span class="w-1.5 h-6 bg-brand-500 rounded-full"></span> 
      হাদিস গ্রন্থসমূহ
    </h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-6">
      {books.map((book) => (
        <a href={`/${book.id}`} class="group bg-white dark:bg-slate-800/50 p-6 rounded-2xl border border-slate-100 dark:border-slate-700/50 hover:border-brand-500/50 hover:shadow-md transition-all duration-300">
          <div class="flex justify-between items-start mb-4">
            <h3 class="text-xl font-bold group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">{book.title}</h3>
            <span class="text-xs font-semibold text-slate-500 bg-slate-100 dark:bg-slate-800 px-3 py-1 rounded-lg">
              {book.total} হাদিস
            </span>
          </div>
          <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
            {book.description}
          </p>
        </a>
      ))}
    </div>
  </section>
</Layout>
