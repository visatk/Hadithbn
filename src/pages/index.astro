---
import Layout from '../layouts/Layout.astro';
import HadithCard from '../components/HadithCard.astro';

// Access Cloudflare D1 Database binding via Astro Locals
const db = Astro.locals.runtime.env.DB;

let hadiths = [];

try {
  // Replace 'hadith_table' with your actual table name from the sqlite files
  const { results } = await db.prepare("SELECT * FROM hadith_table LIMIT 10").all();
  hadiths = results;
} catch (error) {
  console.error("Database fetch error:", error);
}

// Set Edge Caching so D1 is not queried on every single user request (Crucial for Cloudflare)
Astro.response.headers.set('Cache-Control', 's-maxage=86400, stale-while-revalidate');
---

<Layout title="হাদিস সংগ্রহ">
  <div class="max-w-4xl mx-auto py-8 px-4">
    <h1 class="text-3xl font-bold mb-8 text-slate-900 dark:text-white">সর্বশেষ হাদিসসমূহ</h1>
    
    <div class="space-y-6">
      {hadiths.map((hadith) => (
        <HadithCard 
          bookName={hadith.book_name} 
          hadithNumber={hadith.hadith_no} 
          arabicText={hadith.ar} 
          banglaTranslation={hadith.bd} 
          narrator={hadith.narrator} 
          grade={hadith.grade} 
        />
      ))}
    </div>
  </div>
</Layout>
