---
import Layout from '../layouts/Layout.astro';

// Initialize D1 Database
const db = Astro.locals.runtime.env.DB;
let books = [];

try {
  // Fetch all books from D1
  const { results } = await db.prepare("SELECT * FROM books").all();
  books = results;
} catch (error) {
  console.error("D1 Fetch Error:", error);
}

// Cloudflare Edge Caching (Cache for 24 hours)
Astro.response.headers.set('Cache-Control', 'public, max-age=86400, s-maxage=86400, stale-while-revalidate=3600');
---

<Layout title="মূল পাতা">
  <section class="py-12 md:py-20 text-center">
    <span class="bg-brand-100 dark:bg-brand-900/40 text-brand-600 dark:text-brand-400 text-sm font-semibold px-4 py-1.5 rounded-full mb-6 inline-block">
      বিসমিল্লাহির রাহমানির রাহিম
    </span>
    <h1 class="text-4xl md:text-5xl lg:text-6xl mb-4 leading-tight">
      বিশুদ্ধ হাদিস পড়ুন <br/> <span class="text-brand-600 dark:text-brand-500">সহজ ও সাবলীলভাবে</span>
    </h1>
    <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto mb-10">
      কোনো বিজ্ঞাপন বা ডিস্ট্রাকশন ছাড়াই আপনার মাতৃভাষায় প্রামাণ্য হাদিস অধ্যয়ন করুন।
    </p>
  </section>

  <section class="py-10">
    <h2 class="text-2xl mb-8 flex items-center gap-2 font-bold">
      <span class="w-1.5 h-6 bg-brand-500 rounded-full"></span> 
      হাদিস গ্রন্থসমূহ
    </h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {books.map((book) => (
        <a href={`/${book.book_name || book.abvr_code}`} class="group bg-white dark:bg-slate-800/50 p-6 rounded-2xl border border-slate-100 dark:border-slate-700/50 hover:border-brand-500/50 hover:shadow-md transition-all duration-300">
          <div class="flex justify-between items-start mb-4">
            <h3 class="text-xl font-bold group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
              {book.title_bn}
            </h3>
            <span class="text-xs font-semibold text-slate-500 bg-slate-100 dark:bg-slate-800 px-3 py-1 rounded-lg">
              {book.number_of_hadis_bn} হাদিস
            </span>
          </div>
          <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed line-clamp-2">
            {book.book_descr_bn}
          </p>
        </a>
      ))}
    </div>
  </section>
</Layout>
