{
  "compatibility_date": "2026-06-03",
  "compatibility_flags": ["global_fetch_strictly_public"],
  "name": "hadith",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "hadith_db",
      "database_id": "YOUR_D1_DATABASE_ID_HERE"
    }
  ]
}
